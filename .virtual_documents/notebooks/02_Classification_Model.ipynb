#Create sensor trend features
important_sensors = [
    "sensor_11",
    "sensor_4",
    "sensor_15",
    "sensor_2",
    "sensor_17"
]

for sensor in important_sensors:
    df2[f"{sensor}_diff"] = (
        df2.groupby("engine_id")[sensor]
           .diff()
           .fillna(0)
    )


#Create rolling averages
for sensor in important_sensors:
    df2[f"{sensor}_avg5"] = (
        df2.groupby("engine_id")[sensor]
           .transform(
               lambda x: x.rolling(
                   window=5,
                   min_periods=1
               ).mean()
           )
    )


#Build feature list
base_features = [
    "cycle",
    "op_setting_1",
    "op_setting_2",
    "sensor_2",
    "sensor_3",
    "sensor_4",
    "sensor_6",
